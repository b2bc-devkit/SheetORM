# ──────────────────────────────────────────────────────────
# SheetORM .gitignore
# ──────────────────────────────────────────────────────────

# --- Dependencies ---
node_modules

# --- Build artifacts ---
# Compiled output generated by the build scripts (build-npm.mjs, build.mjs)
build
dist

# --- Google Apps Script (GAS) ---
# Bundled GAS entry point produced by Vite/Webpack – regenerated on every build
Code.js
# clasp project config contains a Google Apps Script project ID (scriptId)
.clasp.json
# clasp local auth cache
.tmp-localstorage

# --- Temporary / test artifacts ---
# Folder used for storing intermediate test logs
tmp/

# --- Environment & secrets ---
# Never commit environment files that may contain API keys or tokens
.env
.env.*

# npm / yarn auth tokens
.npmrc
.yarnrc
.yarnrc.yml

# --- Private keys & certificates ---
*.pem
*.key
*.p12
*.pfx

# --- IDE / editor settings ---
.idea/
.vscode/
*.swp
*.swo

# --- OS metadata ---
.DS_Store
Thumbs.db